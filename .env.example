# Runtime-only settings. Tailscale and Mattermost credentials are entered in the web UI.
TAILSTATE_IMAGE=ghcr.io/crypt0rr/tailstate:latest
TAILSTATE_BIND_ADDRESS=127.0.0.1
TAILSTATE_PORT=8080
TAILSTATE_MASTER_KEY_FILE=./secrets/tailstate_master_key
TAILSTATE_COOKIE_SECURE=false
TAILSTATE_LOG_LEVEL=info
